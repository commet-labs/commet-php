{
    "name": "commet/commet-php",
    "description": "Commet PHP SDK - Billing and usage tracking for SaaS applications",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Commet",
            "email": "dev@commet.co"
        }
    ],
    "require": {
        "php": "^8.1",
        "guzzlehttp/guzzle": "^7.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "Commet\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Commet\\Tests\\": "tests/"
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
